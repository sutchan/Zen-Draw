# CODEOWNERS — 代码审查责任人配置
# 当 PR 修改对应文件时，自动请求指定审查者

# 项目所有者（所有变更都需要至少一人审查）
*       @your-github-username

# 核心应用逻辑
/app/hooks/*           @your-github-username
/app/lib/*              @your-github-username

# UI 组件
/app/components/ui/*    @your-github-username
/app/components/draw/*  @your-github-username

# 主题和样式
/app/style.css          @your-github-username
/app/components/theme-provider.tsx  @your-github-username
/tailwind.config.*      @your-github-username

# 配置和构建
/next.config.ts         @your-github-username
/package.json           @your-github-username
/tsconfig.json          @your-github-username
/eslint.config.js       @your-github-username

# 文档
/*.md                   @your-github-username
/.github/*              @your-github-username

# 原型设计文件
/prototype/*            @your-github-username
